# Copy to .env and fill (do not commit .env)
# MinIO in Kubernetes — reach from host via ingress (see ACCESS.md) or NodePort/LB.

# Public ingress (default in gitops)
AWS_ENDPOINT_URL=https://s3.multiagent.vision
AWS_DEFAULT_REGION=us-east-1

# From: kubectl -n minio get secret minio-root-credentials -o jsonpath='{.data.rootUser}' | base64 -d
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Optional: Cloudflare Access (if curl path in script uses them)
# CF_ACCESS_CLIENT_ID=
# CF_ACCESS_CLIENT_SECRET=

# Alternative: internal NodePort / tailnet IP (uncomment and adjust)
# AWS_ENDPOINT_URL=http://100.77.x.x:3xxxx
