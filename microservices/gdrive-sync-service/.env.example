LOG_LEVEL=INFO

# Async SQLAlchemy URL (asyncpg)
DATABASE_URL=postgresql+asyncpg://gdrive:gdrive@postgres:5432/gdrive_sync

REDIS_URL=redis://redis:6379/0

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio12345
# Prod chess-ai bucket (see train README / MinIO console chess-ai/video/…)
MINIO_BUCKET=chess-ai
MINIO_SECURE=false

# Mounted drives.yaml (see config/config.example.yaml)
DRIVES_CONFIG_PATH=/config/drives.yaml

SYNC_INTERVAL_SECONDS=300
STALE_PROCESSING_SECONDS=3600
MAX_UPLOAD_ATTEMPTS=5

DRIVE_READ_CHUNK_SIZE=8388608
MULTIPART_THRESHOLD_BYTES=33554432
MULTIPART_PART_SIZE=16777216

# Optional overrides (defaults fall back to REDIS_URL)
# CELERY_BROKER_URL=redis://redis:6379/0
# CELERY_RESULT_BACKEND=redis://redis:6379/0

# Optional: POST /webhooks/drive shared secret (not implemented in MVP)
# DRIVE_WEBHOOK_SECRET=
